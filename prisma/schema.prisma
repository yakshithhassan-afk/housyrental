generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  TENANT
  ADMIN
  AGENT
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  CONDO
  TOWNHOUSE
  STUDIO
  OFFICE
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  SOLD
  PENDING
  MAINTENANCE
}

enum ListingType {
  RENT
  SALE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum InquiryStatus {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  NEGOTIATING
  CLOSED
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?   @unique
  role          UserRole  @default(TENANT)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Profile fields
  address       String?
  city          String?
  state         String?
  country       String?
  zipCode       String?   @map("zip_code")
  dateOfBirth   DateTime? @map("date_of_birth")
  bio           String?   @db.Text
  
  // KYC fields
  kycStatus     VerificationStatus @default(UNVERIFIED) @map("kyc_status")
  kycDocuments  Json?     @map("kyc_documents")
  
  // Subscription
  subscriptionTier String @default("free") @map("subscription_tier")
  subscriptionExpiry DateTime? @map("subscription_expiry")

  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  inquiries     Inquiry[] @relation("InquiryTenant")
  inquiriesReceived Inquiry[] @relation("InquiryOwner")
  messages      Message[]
  conversations ConversationParticipant[]
  payments      Payment[]
  reviews       Review[]
  viewings      Viewing[]
  
  @@map("users")
}

model Property {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  title       String
  description String?  @db.Text
  type        PropertyType
  listingType ListingType @map("listing_type")
  status      PropertyStatus @default(AVAILABLE)
  
  // Location
  address     String
  city        String
  state       String
  country     String @default("India")
  zipCode     String @map("zip_code")
  latitude    Float?
  longitude   Float?
  
  // Pricing
  price       Float
  maintenanceCharges Float? @map("maintenance_charges")
  securityDeposit Float? @map("security_deposit")
  
  // Details
  bedrooms    Int?
  bathrooms   Int?
  squareFeet  Int?    @map("square_feet")
  furnished   Boolean @default(false)
  parking     Boolean @default(false)
  petsAllowed Boolean @default(false) @map("pets_allowed")
  
  // Verification
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verifiedAt  DateTime? @map("verified_at")
  verifiedBy  String?   @map("verified_by")
  
  // Amenities
  amenities   PropertyAmenity[]
  
  // Media
  images      PropertyImage[]
  
  // Metadata
  featured    Boolean @default(false)
  views       Int     @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  inquiries   Inquiry[]
  viewings    Viewing[]
  reviews     Review[]
  
  @@index([city])
  @@index([status])
  @@index([listingType])
  @@index([price])
  @@index([verificationStatus])
  @@index([latitude, longitude])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  url         String
  storagePath String?  @map("storage_path")
  order       Int      @default(0)
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@map("property_images")
}

model Amenity {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String?
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  
  properties  PropertyAmenity[]
  
  @@map("amenities")
}

model PropertyAmenity {
  propertyId  String   @map("property_id")
  amenityId   String   @map("amenity_id")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity     Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model Inquiry {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  tenantId    String   @map("tenant_id")
  ownerId     String   @map("owner_id")
  message     String?  @db.Text
  status      InquiryStatus @default(NEW)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      User     @relation("InquiryTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User     @relation("InquiryOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@index([tenantId])
  @@index([ownerId])
  @@map("inquiries")
}

model Conversation {
  id          String   @id @default(cuid())
  propertyId  String?  @map("property_id")
  inquiryId   String?  @map("inquiry_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  participants ConversationParticipant[]
  messages     Message[]
  
  @@index([propertyId])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String @map("conversation_id")
  userId         String @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.Text
  attachments    Json?    // Array of {url, type, name}
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Viewing {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  tenantId    String   @map("tenant_id")
  scheduledAt DateTime @map("scheduled_at")
  status      String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@index([tenantId])
  @@index([scheduledAt])
  @@map("viewings")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  propertyId  String?  @map("property_id")
  amount      Float
  currency    String   @default("INR")
  type        String   // rent, deposit, subscription, token
  status      PaymentStatus @default(PENDING)
  stripePaymentId String? @map("stripe_payment_id")
  razorpayOrderId String? @map("razorpay_order_id")
  razorpayPaymentId String? @map("razorpay_payment_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([propertyId])
  @@map("payments")
}

model Review {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  reviewerId  String   @map("reviewer_id")
  rating      Int      // 1-5
  comment     String?  @db.Text
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviewer    User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  
  @@unique([propertyId, reviewerId])
  @@index([propertyId])
  @@map("reviews")
}
